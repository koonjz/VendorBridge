generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String // "Admin", "Procurement Officer", "Manager", "Vendor"
  vendorId  String?  @unique // Nullable: only Vendors have this
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor? @relation(fields: [vendorId], references: [id])
  rfqs   Rfq[]   @relation("UserRfqs")
}

model Vendor {
  id            String   @id @default(uuid())
  companyName   String
  contactPerson String
  email         String
  phone         String
  gst           String
  address       String
  category      String
  country       String
  notes         String?
  status        String   @default("Pending") // Active, Pending, Inactive
  rating        Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user           User?
  quotations     Quotation[]
  approvals      Approval[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]

  // Implicit many-to-many relation with Rfq
  rfqs Rfq[] @relation("VendorRfqs")
}

model Rfq {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  quantity    Int
  unit        String
  budget      Float
  priority    String // Low, Medium, High, Urgent
  deadline    DateTime
  status      String   @default("Open") // Draft, Open, Closed, Approved, Cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy String
  creator   User   @relation("UserRfqs", fields: [createdBy], references: [id])

  quotations     Quotation[]
  approvals      Approval[]
  purchaseOrders PurchaseOrder[]

  // Implicit many-to-many relation with Vendor
  assignedVendors Vendor[] @relation("VendorRfqs")
}

model Quotation {
  id                   String   @id @default(uuid())
  price                Float
  currency             String
  tax                  Float
  discount             Float
  finalAmount          Float
  deliveryDays         Int
  expectedDeliveryDate DateTime
  warranty             String?
  paymentTerms         String?
  notes                String?
  status               String   @default("Submitted") // Submitted, Selected, Rejected
  submittedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  rfqId    String
  rfq      Rfq    @relation(fields: [rfqId], references: [id])
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  approvals      Approval[]
  purchaseOrders PurchaseOrder[]
}

model Approval {
  id               String   @id @default(uuid())
  recommendedScore Float
  status           String   @default("Pending") // Pending, Approved, Rejected
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  rfqId       String
  rfq         Rfq       @relation(fields: [rfqId], references: [id])
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  vendorId    String
  vendor      Vendor    @relation(fields: [vendorId], references: [id])

  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id               String   @id @default(uuid())
  status           String   @default("Issued") // Draft, Issued, Acknowledged, In Progress, Delivered, Closed, Cancelled
  issueDate        DateTime @default(now())
  expectedDelivery DateTime
  subtotal         Float
  tax              Float
  discount         Float
  total            Float
  items            Json // Storing line items as JSON for simplicity
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  rfqId       String
  rfq         Rfq       @relation(fields: [rfqId], references: [id])
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  approvalId  String
  approval    Approval  @relation(fields: [approvalId], references: [id])
  vendorId    String
  vendor      Vendor    @relation(fields: [vendorId], references: [id])

  invoices Invoice[]
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  billingDate   DateTime @default(now())
  dueDate       DateTime
  subtotal      Float
  tax           Float
  discount      Float
  grandTotal    Float
  status        String   @default("Sent") // Draft, Sent, Paid, Overdue, Cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  vendorId        String
  vendor          Vendor        @relation(fields: [vendorId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String // Can be 'all' or a specific User ID
  type        String // "RFQ", "Approval", "Invoice", "System", etc.
  title       String
  description String
  status      String   @default("unread")
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String // Can be 'System' or a specific User ID
  role      String
  module    String // "RFQs", "Vendors", "Quotations", "Approvals", "Purchase Orders", "Invoices", "System"
  action    String
  details   String
  status    String // "success", "info", "warning", "danger"
  ipAddress String
  createdAt DateTime @default(now())
}
